### Test 1: Valid Order Creation
POST http://localhost:5250/api/orders
Content-Type: application/json

{
  "items": [
    {
      "productId": 1,
      "quantity": 2,
      "unitPrice": 299.99
    }
  ],
  "totalAmount": 599.98,
  "shippingAddress": {
    "fullName": "John Doe",
    "email": "john.doe@example.com",
    "phone": "555-123-4567",
    "streetAddress": "123 Main Street",
    "city": "Seattle",
    "state": "WA",
    "postalCode": "98101",
    "country": "USA"
  },
  "customerEmail": "john.doe@example.com",
  "customerName": "John Doe"
}

