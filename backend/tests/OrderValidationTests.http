### Test 10: String Length Violation (FullName > 200 chars)
POST http://localhost:5250/api/orders
Content-Type: application/json

{
  "items": [
    {
      "productId": 1,
      "quantity": 1,
      "unitPrice": 299.99
    }
  ],
  "totalAmount": 299.99,
  "shippingAddress": {
    "fullName": "ThisIsAnExtremelyLongNameThatExceedsTheTwoHundredCharacterLimitAndShouldBeRejectedByTheValidationLogicBecauseItIsTooLongForOurDatabaseFieldAndWouldCauseProblemsInProductionSystemsWhereDataIntegrityIsImportantSoWeNeedToValidateItProperly",
    "email": "test@example.com",
    "phone": "555-000-0000",
    "streetAddress": "789 Test St",
    "city": "Test City",
    "state": "TC",
    "postalCode": "12345",
    "country": "USA"
  },
  "customerEmail": "test@example.com",
  "customerName": "Test User"
}
